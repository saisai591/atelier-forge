export XDG_RUNTIME_DIR=/tmp/aos-runtime-root
export MOZ_ENABLE_WAYLAND=0
export MOZ_DISABLE_NONLOCAL_CONNECTIONS=1
mkdir -p "\${XDG_RUNTIME_DIR}"
chmod 700 "\${XDG_RUNTIME_DIR}"
mkdir -p /root/.mozilla/firefox/aos.default
cat > /root/.mozilla/firefox/profiles.ini <<'PREFEOF'
[General]
StartWithLastProfile=1

[Profile0]
Name=aos
IsRelative=1
Path=aos.default
Default=1
PREFEOF
cat > /root/.mozilla/firefox/aos.default/user.js <<'PREFEOF'
user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("browser.startup.page", 0);
user_pref("browser.startup.homepage_override.mstone", "ignore");
user_pref("browser.sessionstore.resume_from_crash", false);
user_pref("browser.tabs.warnOnClose", false);
