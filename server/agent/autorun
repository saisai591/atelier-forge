            WORKSHOP_TESTS_JSON="$(python3 - <<'PY'
import json, datetime
print(json.dumps({
  "created_at": datetime.datetime.utcnow().isoformat() + "Z",
  "pixel": "browser_tool",
  "keyboard": "browser_tool",
  "usb": "browser_tool",
