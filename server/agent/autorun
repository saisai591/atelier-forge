}))
PY
)"
        echo "Interface graphique indisponible. Audit envoye sans fallback interactif."
        return 0
    fi

    clear || true
    echo "============================================================"
    echo " AOS Deploy - Test atelier rapide"
    echo " Machine : ${BRAND} ${MODEL}"
    echo " Serie   : ${SERIAL:-inconnue}"
    echo " IP      : ${IP_ADDR}"
    echo "============================================================"
    echo ""

    show_color_screen "40;97" "TEST PIXELS - NOIR"
    show_color_screen "47;30" "TEST PIXELS - BLANC"
    show_color_screen "41;97" "TEST PIXELS - ROUGE"
    show_color_screen "42;30" "TEST PIXELS - VERT"
    show_color_screen "44;97" "TEST PIXELS - BLEU"
    local pixel_test keyboard_test usb_test audio_test mic_test camera_test
    pixel_test="$(ask_ok 'Ecran / pixels OK ?')"

    keyboard_test="$(run_keyboard_visual_test)"

    echo ""
    echo "Test USB : branchez une cle/peripherique USB maintenant, puis ENTREE."
    local usb_before usb_after
    usb_before="$(lsusb 2>/dev/null | wc -l || echo 0)"
    read -r _
    sleep 2
    usb_after="$(lsusb 2>/dev/null | wc -l || echo 0)"
    if [[ "${usb_after}" -gt "${usb_before}" ]]; then
        usb_test="ok"
        echo "USB detecte (${usb_before} -> ${usb_after})."
    else
        usb_test="$(ask_ok 'USB OK malgre absence de nouveau peripherique ?')"
    fi

    echo ""
    if command -v speaker-test >/dev/null 2>&1; then
        timeout 4s speaker-test -t sine -f 880 -l 1 >/dev/null 2>&1 || true
    elif command -v aplay >/dev/null 2>&1; then
        printf '\a' || true
    fi
    audio_test="$(ask_ok 'Son haut-parleur OK ?')"

    echo ""
    if command -v arecord >/dev/null 2>&1 && arecord -l >/dev/null 2>&1; then
        echo "Test micro : parlez 3 secondes..."
        timeout 4s arecord -q -d 3 -f cd /tmp/forge-mic-test.wav >/dev/null 2>&1 || true
        if [[ -s /tmp/forge-mic-test.wav ]]; then mic_test="ok"; else mic_test="fail"; fi
    else
        mic_test="$(ask_ok 'Micro OK / non teste manuellement ?')"
    fi

    echo ""
    if ls /dev/video* >/dev/null 2>&1; then
        if command -v ffmpeg >/dev/null 2>&1; then
            timeout 6s ffmpeg -y -f v4l2 -i /dev/video0 -frames:v 1 /tmp/forge-camera.jpg >/dev/null 2>&1 || true
        fi
        if [[ -s /tmp/forge-camera.jpg || -e /dev/video0 ]]; then camera_test="ok"; else camera_test="fail"; fi
    else
        camera_test="$(ask_ok 'Camera OK / absente volontairement ?')"
    fi

    WORKSHOP_TESTS_JSON="$(PIXEL="${pixel_test}" KEYBOARD="${keyboard_test}" USB="${usb_test}" AUDIO="${audio_test}" MIC="${mic_test}" CAMERA="${camera_test}" python3 - <<'PY'
import json, os, datetime
print(json.dumps({
  "created_at": datetime.datetime.utcnow().isoformat() + "Z",
  "pixel": os.environ.get("PIXEL", "not_run"),
  "keyboard": os.environ.get("KEYBOARD", "not_run"),
  "usb": os.environ.get("USB", "not_run"),
  "audio": os.environ.get("AUDIO", "not_run"),
  "microphone": os.environ.get("MIC", "not_run"),
