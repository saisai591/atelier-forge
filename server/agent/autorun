write_audit_file() {
    local audit_dir="/mnt/forge-deploy/audit"
    local local_audit_dir="/tmp/forge-audit"
    mkdir -p /mnt/forge-deploy
    if ! mountpoint -q /mnt/forge-deploy; then
        mount -t cifs "//${FORGE_HOST}/deploy" /mnt/forge-deploy \
            -o "username=${FORGE_SMB_USER},password=${FORGE_SMB_PASS},vers=3.0,rw,noperm" 2>/tmp/forge-cifs.err || {
            echo "Montage SMB impossible: $(cat /tmp/forge-cifs.err 2>/dev/null)"
            audit_dir="${local_audit_dir}"
        }
    fi
    mkdir -p "${audit_dir}"
    FORGE_ID_E="${FORGE_ID}" HOSTNAME_E="${HOSTNAME}" IP_ADDR_E="${IP_ADDR}" MAC_ADDR_E="${MAC_ADDR}" \
    SERIAL_E="${SERIAL}" BRAND_E="${BRAND}" MODEL_E="${MODEL}" CPU_MODEL_E="${CPU_MODEL}" \
    PRODUCT_UUID_E="${PRODUCT_UUID}" BIOS_VENDOR_E="${BIOS_VENDOR}" BIOS_VERSION_E="${BIOS_VERSION}" BIOS_DATE_E="${BIOS_DATE}" \
    BOARD_VENDOR_E="${BOARD_VENDOR}" BOARD_NAME_E="${BOARD_NAME}" CHASSIS_TYPE_E="${CHASSIS_TYPE}" \
    CPU_TEST_E="${CPU_TEST}" RAM_MB_E="${RAM_MB}" RAM_TEST_E="${RAM_TEST}" MEMORY_MODULES_JSON_E="${MEMORY_MODULES_JSON}" \
    RESOLUTION_E="${RESOLUTION}" NETWORK_JSON_E="${NETWORK_JSON}" TPM_JSON_E="${TPM_JSON}" USB_JSON_E="${USB_JSON}" \
    GPU_JSON_E="${GPU_JSON}" AC_POWER_JSON_E="${AC_POWER_JSON}" MEDIA_JSON_E="${MEDIA_JSON}" \
    BATTERIES_JSON_E="${BATTERIES_JSON}" DISKS_JSON_E="${DISKS_JSON}" DISK_TESTS_JSON_E="${DISK_TESTS_JSON}" WORKSHOP_TESTS_JSON_E="${WORKSHOP_TESTS_JSON}" \
    GRADE_E="${GRADE}" AUDIT_DIR_E="${audit_dir}" FORGE_CONTROL_API_E="${FORGE_CONTROL_API}" python3 - <<'PY'
import json, os, pathlib, datetime
from urllib import request
from urllib.error import URLError
def env(name):
    return os.environ.get(name, "")
def env_json(name):
    try:
        return json.loads(env(name) or "[]")
    except json.JSONDecodeError:
        return []
audit = {
  "type": "atelier-forge-diag-express",
  "created_at": datetime.datetime.utcnow().isoformat() + "Z",
  "client_id": env("FORGE_ID_E"),
  "hostname": env("HOSTNAME_E"),
  "ip": env("IP_ADDR_E"),
  "mac": env("MAC_ADDR_E"),
  "serial_number": env("SERIAL_E"),
  "product_uuid": env("PRODUCT_UUID_E"),
  "brand": env("BRAND_E"),
  "model": env("MODEL_E"),
  "bios": {"vendor": env("BIOS_VENDOR_E"), "version": env("BIOS_VERSION_E"), "date": env("BIOS_DATE_E")},
  "board": {"vendor": env("BOARD_VENDOR_E"), "name": env("BOARD_NAME_E")},
  "chassis": {"type": env("CHASSIS_TYPE_E")},
  "cpu": {"model": env("CPU_MODEL_E"), "quick_test": env("CPU_TEST_E")},
  "ram": {"total_mb": env("RAM_MB_E"), "quick_test": env("RAM_TEST_E"), "modules": env_json("MEMORY_MODULES_JSON_E")},
  "network": env_json("NETWORK_JSON_E"),
  "tpm": env_json("TPM_JSON_E"),
  "usb": env_json("USB_JSON_E"),
  "display": {"resolution": env("RESOLUTION_E"), "gpu": env_json("GPU_JSON_E"), "pixel_test": "technician_required"},
  "power": {"ac_adapters": env_json("AC_POWER_JSON_E")},
  "media": env_json("MEDIA_JSON_E"),
  "keyboard": {"test": "technician_required"},
  "touchpad": {"test": "technician_required"},
  "battery": env_json("BATTERIES_JSON_E"),
  "disks": env_json("DISKS_JSON_E"),
  "disk_tests": env_json("DISK_TESTS_JSON_E"),
  "workshop_tests": env_json("WORKSHOP_TESTS_JSON_E"),
  "grade_proposed": env("GRADE_E"),
  "checks_required": ["pixels", "keyboard", "touchpad", "cosmetic"]
}
safe = (audit.get("serial_number") or audit.get("mac") or audit.get("hostname") or "pc").replace("/", "-").replace(":", "")
path = pathlib.Path(env("AUDIT_DIR_E")) / f"{safe}.json"
path.write_text(json.dumps(audit, indent=2, ensure_ascii=False), encoding="utf-8")
(pathlib.Path(env("AUDIT_DIR_E")) / "latest.json").write_text(json.dumps(audit, indent=2, ensure_ascii=False), encoding="utf-8")
def fmt_ram(total_mb):
    try:
        mb = int(float(total_mb))
        gb = mb / 1024
        return f"{gb:.0f} GB" if gb >= 10 else f"{gb:.1f} GB"
    except (TypeError, ValueError):
        return ""

def fmt_disk(disk):
    size = disk.get("size_gb")
    size_text = f"{size:g} GB" if isinstance(size, (int, float)) else ""
    model = (disk.get("model") or "").strip()
    dtype = (disk.get("type") or "").strip()
    smart = (disk.get("smart") or "").strip()
    parts = [part for part in (size_text, dtype, model) if part]
    text = " ".join(parts)
    return {"text": text, "smart": smart, **disk}

def fmt_battery(item):
    status = item.get("status") or "unknown"
    health = item.get("health_percent")
    wear = item.get("wear_percent")
    cycles = item.get("cycle_count")
    return {
        "name": item.get("name"),
        "status": status,
        "health_percent": health,
        "wear_percent": wear,
        "cycle_count": cycles,
        "label": (
            f"{status} | Sante {health}% | Usure {wear}%"
            if health is not None and wear is not None
            else f"{status} | Usure inconnue"
        ),
    }

label_disks = [fmt_disk(disk) for disk in audit.get("disks", []) if isinstance(disk, dict)]
label_batteries = [fmt_battery(item) for item in audit.get("battery", []) if isinstance(item, dict)]
main_disk = label_disks[0]["text"] if label_disks else ""
main_battery = label_batteries[0]["label"] if label_batteries else "Aucune batterie detectee"
label = {
  "serial_number": audit.get("serial_number"),
  "brand": audit.get("brand"),
  "model": audit.get("model"),
  "machine": {
    "brand": audit.get("brand"),
    "model": audit.get("model"),
    "serial_number": audit.get("serial_number"),
  },
  "cpu": (audit.get("cpu") or {}).get("model"),
  "ram_mb": (audit.get("ram") or {}).get("total_mb"),
  "ram": fmt_ram((audit.get("ram") or {}).get("total_mb")),
  "disks": label_disks,
  "main_disk": main_disk,
  "battery": label_batteries,
  "battery_status": main_battery,
  "usb_ports_detected": len(audit.get("usb") or []),
  "mac": audit.get("mac"),
  "ip": audit.get("ip"),
  "grade_proposed": audit.get("grade_proposed"),
  "workshop_tests": audit.get("workshop_tests") or {},
  "label_lines": [
    f"{audit.get('brand','')} {audit.get('model','')}".strip(),
    f"SN: {audit.get('serial_number','')}",
    f"CPU: {(audit.get('cpu') or {}).get('model','')}",
    f"RAM: {fmt_ram((audit.get('ram') or {}).get('total_mb'))}",
    f"DISQUE: {main_disk}",
    f"BATTERIE: {main_battery}",
  ],
}
label_path = pathlib.Path(env("AUDIT_DIR_E")) / f"{safe}.label.json"
label_path.write_text(json.dumps(label, indent=2, ensure_ascii=False), encoding="utf-8")
(pathlib.Path(env("AUDIT_DIR_E")) / "latest-label.json").write_text(json.dumps(label, indent=2, ensure_ascii=False), encoding="utf-8")
api = env("FORGE_CONTROL_API_E").rstrip("/")
if api:
    body = json.dumps({"audit": audit, "label": label}, ensure_ascii=False).encode("utf-8")
    req = request.Request(
        f"{api}/forge/pxe/audits/upload",
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        request.urlopen(req, timeout=8).read()
        print(f"Audit envoye vers {api}/forge/pxe/audits/upload")
    except (OSError, URLError) as exc:
        print(f"Envoi HTTP audit impossible: {exc}")
print(path)
PY
}

