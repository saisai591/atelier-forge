ask_ok() {
    local prompt="$1"
    local answer
    printf "%s [o/N] " "${prompt}" >"${FORGE_TEST_TTY}"
    read -r answer <"${FORGE_TEST_TTY}"
    case "${answer}" in
        o|O|oui|OUI|y|Y|yes|YES) echo "ok" ;;
        *) echo "fail" ;;
    esac
}

show_color_screen() {
    local code="$1" label="$2"
    local cols lines row
    cols="$(tput cols 2>/dev/null || echo 80)"
    lines="$(tput lines 2>/dev/null || echo 25)"
    {
        printf '\033[2J\033[H\033[%sm' "${code}"
        for ((row=1; row<=lines; row++)); do
            printf '%*s' "${cols}" ''
        done
        printf '\033[H'
        printf '\033[1m'
        printf '\n\n  %s\n' "${label}"
        printf '  Inspectez toute la dalle : pixel mort, ligne, tache, fuite de lumiere.\n'
        printf '  Appuyez sur ENTREE pour la couleur suivante.'
    } >"${FORGE_TEST_TTY}"
    read -r _ <"${FORGE_TEST_TTY}"
    printf '\033[0m\033[2J\033[H' >"${FORGE_TEST_TTY}"
}

draw_keyboard() {
    local pressed="$1"
    local key token
    local rows=(
        "ESC F1 F2 F3 F4 F5 F6 F7 F8 F9 F10 F11 F12"
        "² & é \" ' ( - è _ ç à ) = BACK"
        "TAB A Z E R T Y U I O P ^ $"
        "CAPS Q S D F G H J K L M ù * ENTER"
        "SHIFT < W X C V B N , ; : ! SHIFT"
        "CTRL FN WIN ALT SPACE ALTGR MENU CTRL"
        "NUM / * - 7 8 9 + 4 5 6 1 2 3 ENTER 0 ."
    )
    {
        printf '\033[2J\033[H'
        echo "============================================================"
        echo " AOS Deploy - Test clavier visuel"
        echo " Tapez les touches principales. Les touches saisies passent en vert."
        echo " ENTREE termine le test, ECHAP annule."
        echo "============================================================"
        echo ""
        for row in "${rows[@]}"; do
            for key in ${row}; do
                token="${key^^}"
                if [[ "${pressed}" == *"|${token}|"* ]]; then
                    printf '\033[42;30m %-6s \033[0m' "${key}"
                else
                    printf '\033[100;97m %-6s \033[0m' "${key}"
                fi
            done
            echo ""
            echo ""
        done
        echo "Touches vues: ${pressed//|/ }"
    } >"${FORGE_TEST_TTY}"
}

normalize_key_token() {
    local char="$1"
    case "${char}" in
        " ") echo "SPACE" ;;
        $'\t') echo "TAB" ;;
        $'\e') echo "ESC" ;;
        $'\177') echo "BACK" ;;
        *) printf '%s' "${char^^}" ;;
    esac
}

run_keyboard_visual_test() {
    local pressed="|" char token count=0
    stty -echo -icanon time 0 min 1 <"${FORGE_TEST_TTY}" 2>/dev/null || true
    while true; do
        draw_keyboard "${pressed}"
        IFS= read -rsn1 char <"${FORGE_TEST_TTY}" || true
        [[ "${char}" == $'\n' || "${char}" == $'\r' ]] && break
        [[ "${char}" == $'\e' ]] && { stty sane <"${FORGE_TEST_TTY}" 2>/dev/null || true; echo "fail"; return; }
        token="$(normalize_key_token "${char}")"
        if [[ -n "${token}" && "${pressed}" != *"|${token}|"* ]]; then
            pressed+="${token}|"
            count=$((count + 1))
        fi
    done
    stty sane <"${FORGE_TEST_TTY}" 2>/dev/null || true
    printf '\033[2J\033[H' >"${FORGE_TEST_TTY}"
    if [[ "${count}" -ge 10 ]]; then
        echo "ok"
    else
        ask_ok "Clavier OK avec seulement ${count} touche(s) detectee(s) ?"
    fi
}

urlencode() {
    VALUE="$1" python3 - <<'PY'
import os
from urllib.parse import quote
print(quote(os.environ.get("VALUE", ""), safe=""))
PY
}

browser_cmd() {
    for candidate in firefox firefox-esr chromium chromium-browser google-chrome; do
        if command -v "${candidate}" >/dev/null 2>&1; then
            echo "${candidate}"
            return 0
        fi
    done
    return 1
}

run_graphical_workshop_tests() {
    local browser startx_cmd url serial_q brand_q model_q
    browser="$(browser_cmd || true)"
    startx_cmd="$(command -v startx 2>/dev/null || true)"
    if [[ -z "${browser}" || -z "${startx_cmd}" ]]; then
        return 1
    fi

    serial_q="$(urlencode "${SERIAL}")"
    brand_q="$(urlencode "${BRAND}")"
    model_q="$(urlencode "${MODEL}")"
    url="${FORGE_SERVER%/}/tests/?serial=${serial_q}&brand=${brand_q}&model=${model_q}&api=${FORGE_CONTROL_API%/}"

    cat > /root/.xinitrc <<EOF
