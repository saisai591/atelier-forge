post_command_result() {
    local command_id="$1"
    local status="$2"
    local message="$3"
    python3 - "$command_id" "$status" "$message" > /tmp/forge-command-result.json <<'PY'
import json, sys, datetime
print(json.dumps({
    "command_id": sys.argv[1],
    "status": sys.argv[2],
    "message": sys.argv[3],
    "finished_at": datetime.datetime.utcnow().isoformat() + "Z",
}))
PY
    curl -fsS \
        -H "Content-Type: application/json" \
        --data-binary @/tmp/forge-command-result.json \
        "${FORGE_CONTROL_API%/}/agent/${FORGE_ID}/result" >/tmp/forge-command-result.out 2>/tmp/forge-command-result.err || true
}

execute_command() {
    local command_id="$1"
    local action="$2"
    case "${action}" in
        diag_express)
            run_diag_express
            write_state
            write_audit_file || true
            post_command_result "${command_id}" "done" "Diagnostic express exécuté"
            ;;
        start_ssh)
            pgrep -x sshd >/dev/null 2>&1 || /usr/bin/sshd 2>/dev/null || true
            post_command_result "${command_id}" "done" "SSH actif sur ${IP_ADDR}"
            ;;
        open_tests)
            if run_graphical_workshop_tests; then
                post_command_result "${command_id}" "done" "Page tests atelier ouverte"
            else
                post_command_result "${command_id}" "failed" "Impossible d'ouvrir la page tests atelier"
            fi
            ;;
        reboot)
            post_command_result "${command_id}" "accepted" "Redémarrage demandé"
            reboot
            ;;
        poweroff)
            post_command_result "${command_id}" "accepted" "Extinction demandée"
            poweroff
            ;;
        *)
            post_command_result "${command_id}" "ignored" "Action inconnue: ${action}"
            ;;
    esac
}

poll_commands() {
    curl -fsS "${FORGE_CONTROL_API%/}/agent/${FORGE_ID}/commands" -o /tmp/forge-commands.json 2>/tmp/forge-commands.err || return 0
    python3 - <<'PY' > /tmp/forge-commands.tsv
import json
try:
    data=json.load(open('/tmp/forge-commands.json', encoding='utf-8'))
except Exception:
    data=[]
for item in data:
    print(f"{item.get('id','')}\t{item.get('action','')}")
PY
    while IFS=$'\t' read -r command_id action; do
        [[ -n "${command_id}" && -n "${action}" ]] || continue
        echo "Commande reçue: ${command_id} ${action}"
        execute_command "${command_id}" "${action}"
    done < /tmp/forge-commands.tsv
}

write_state
write_audit_file || true
write_client_logs || true
send_heartbeat || true
send_control_heartbeat || true

(
    while true; do
        sleep 10
        write_state
        write_audit_file || true
        write_client_logs || true
        send_heartbeat || true
        send_control_heartbeat || true
        poll_commands || true
    done
) &

echo "Agent pret. IP=${IP_ADDR} MAC=${MAC_ADDR} HOST=${HOSTNAME}"
exit 0
