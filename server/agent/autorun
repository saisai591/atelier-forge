#!/usr/bin/env bash
# Atelier Forge - agent live SystemRescue.
# Demarre les acces de support et publie un heartbeat vers le SaaS si configure.
set +e

LOG="/var/log/atelier-forge-agent.log"
STATE="/tmp/atelier-forge-agent.json"
exec > >(tee -a "${LOG}") 2>&1

echo "== Atelier Forge agent $(date -Is) =="

finish_ok() {
    local code=$?
    echo "AOS Deploy agent termine avec code interne ${code}, retour force OK pour supprimer l'attente autorun."
    exit 0
}
trap finish_ok EXIT

cmdline_value() {
    local key="$1"
    tr ' ' '\n' < /proc/cmdline | awk -F= -v k="${key}" '$1 == k {print substr($0, length(k) + 2); exit}'
}

FORGE_SERVER="$(cmdline_value forge_server)"
FORGE_API="$(cmdline_value forge_api)"
FORGE_KEY="$(cmdline_value forge_key)"
FORGE_ID="$(cmdline_value forge_id)"
FORGE_VNC_INSECURE="$(cmdline_value forge_vnc_insecure)"
FORGE_SMB_USER="$(cmdline_value forge_smb_user)"
FORGE_SMB_PASS="$(cmdline_value forge_smb_pass)"
FORGE_CONTROL_API="$(cmdline_value forge_control_api)"
FORGE_MODE="$(cmdline_value forge_mode)"
FORGE_GUI_TESTS="$(cmdline_value forge_gui_tests)"

if [[ -z "${FORGE_SERVER}" ]]; then
    FORGE_SERVER="http://192.168.1.37:1950"
fi
FORGE_HOST="$(printf '%s' "${FORGE_SERVER}" | sed -E 's#^https?://([^/:]+).*#\1#')"
FORGE_SMB_USER="${FORGE_SMB_USER:-pxe}"
FORGE_SMB_PASS="${FORGE_SMB_PASS:-pxe}"
FORGE_CONTROL_API="${FORGE_CONTROL_API:-http://${FORGE_HOST}:1953/api}"
FORGE_TEST_TTY="/dev/tty1"
if [[ ! -w "${FORGE_TEST_TTY}" ]]; then
    FORGE_TEST_TTY="/dev/console"
fi

if [[ "${FORGE_MODE}" == "quick_audit" || "${FORGE_MODE}" == "test_atelier" ]]; then
    chvt 1 2>/dev/null || true
    exec <"${FORGE_TEST_TTY}" >"${FORGE_TEST_TTY}" 2>&1
fi

primary_ip() {
    ip -4 route get 1.1.1.1 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i=="src") {print $(i+1); exit}}'
}

primary_iface() {
    ip -4 route get 1.1.1.1 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i=="dev") {print $(i+1); exit}}'
}

json_escape() {
    python3 -c 'import json,sys; print(json.dumps(sys.stdin.read().strip()))' 2>/dev/null || printf '"%s"' "$1"
}

HOSTNAME="$(hostname 2>/dev/null || echo sysrescue)"
IP_ADDR="$(primary_ip)"
IFACE="$(primary_iface)"
MAC_ADDR=""
if [[ -n "${IFACE}" && -r "/sys/class/net/${IFACE}/address" ]]; then
    MAC_ADDR="$(cat "/sys/class/net/${IFACE}/address")"
fi
SERIAL="$(cat /sys/class/dmi/id/product_serial 2>/dev/null || true)"
BRAND="$(cat /sys/class/dmi/id/sys_vendor 2>/dev/null || true)"
MODEL="$(cat /sys/class/dmi/id/product_name 2>/dev/null || true)"
PRODUCT_UUID="$(cat /sys/class/dmi/id/product_uuid 2>/dev/null || true)"
BIOS_VENDOR="$(cat /sys/class/dmi/id/bios_vendor 2>/dev/null || true)"
BIOS_VERSION="$(cat /sys/class/dmi/id/bios_version 2>/dev/null || true)"
BIOS_DATE="$(cat /sys/class/dmi/id/bios_date 2>/dev/null || true)"
BOARD_VENDOR="$(cat /sys/class/dmi/id/board_vendor 2>/dev/null || true)"
BOARD_NAME="$(cat /sys/class/dmi/id/board_name 2>/dev/null || true)"
CHASSIS_TYPE="$(cat /sys/class/dmi/id/chassis_type 2>/dev/null || true)"

if [[ -z "${FORGE_ID}" ]]; then
    FORGE_ID="${MAC_ADDR:-${HOSTNAME}}"
fi

read_cpu() {
    awk -F: '/model name/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' /proc/cpuinfo 2>/dev/null
}

read_ram_mb() {
    awk '/MemTotal/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null
}

read_memory_modules_json() {
    python3 - <<'PY'
import json, re, subprocess
items = []
try:
    out = subprocess.run(['dmidecode', '-t', 'memory'], text=True, capture_output=True, timeout=12).stdout
    blocks = re.split(r'\nHandle ', out)
    for block in blocks:
        if 'Memory Device' not in block:
            continue
        data = {}
        for raw in block.splitlines():
            if ':' not in raw:
                continue
            key, value = raw.split(':', 1)
            data[key.strip()] = value.strip()
        size = data.get('Size', '')
        if not size or 'No Module' in size:
            continue
        items.append({
            'slot': data.get('Locator') or data.get('Bank Locator'),
            'size': size,
            'type': data.get('Type'),
            'speed': data.get('Speed'),
            'configured_speed': data.get('Configured Memory Speed'),
            'manufacturer': data.get('Manufacturer'),
            'part_number': data.get('Part Number'),
            'serial_number': data.get('Serial Number'),
        })
except Exception:
    pass
print(json.dumps(items))
PY
}

read_resolution() {
    if command -v fbset >/dev/null 2>&1; then
        fbset 2>/dev/null | awk '/geometry/ {print $2 "x" $3; exit}'
    fi
    for mode in /sys/class/drm/*/modes; do
        [[ -r "${mode}" ]] || continue
        head -n 1 "${mode}" 2>/dev/null && return 0
    done
    if command -v xrandr >/dev/null 2>&1; then
        xrandr 2>/dev/null | awk '/\*/ {print $1; exit}'
    fi
}

read_network_json() {
    python3 - <<'PY'
import json, os, pathlib, subprocess
items = []
for net in sorted(pathlib.Path('/sys/class/net').iterdir()):
    name = net.name
    if name == 'lo':
        continue
    def read(rel):
        try:
            return (net / rel).read_text(encoding='utf-8').strip()
        except OSError:
            return ''
    addrs = []
    try:
        out = subprocess.run(['ip', '-o', 'addr', 'show', 'dev', name], text=True, capture_output=True, timeout=5).stdout
        for line in out.splitlines():
            parts = line.split()
            if len(parts) >= 4 and parts[2] in ('inet', 'inet6'):
                addrs.append({'family': parts[2], 'address': parts[3]})
    except Exception:
        pass
    items.append({
        'name': name,
        'mac': read('address'),
        'state': read('operstate'),
        'carrier': read('carrier') == '1',
        'speed_mbps': read('speed') or None,
        'addresses': addrs,
    })
print(json.dumps(items))
PY
}

read_tpm_json() {
    python3 - <<'PY'
import json, pathlib
items = []
for tpm in sorted(pathlib.Path('/sys/class/tpm').glob('tpm*')):
    item = {'name': tpm.name}
    for rel in ('device/description', 'device/caps', 'device/pcrs'):
        try:
            value = (tpm / rel).read_text(encoding='utf-8', errors='ignore').strip()
            item[rel.replace('/', '_')] = value[:500]
        except OSError:
            pass
    items.append(item)
print(json.dumps({'present': bool(items), 'devices': items}))
PY
}

read_usb_json() {
    python3 - <<'PY'
import json, subprocess
items = []
try:
    out = subprocess.run(['lsusb'], text=True, capture_output=True, timeout=8).stdout
    items = [line.strip() for line in out.splitlines() if line.strip()]
except Exception:
    pass
print(json.dumps(items))
PY
}

read_gpu_json() {
    python3 - <<'PY'
import json, pathlib, subprocess
items = []
try:
    out = subprocess.run(['lspci', '-mm'], text=True, capture_output=True, timeout=8).stdout
    for line in out.splitlines():
        if any(key in line.lower() for key in ('vga compatible controller', '3d controller', 'display controller')):
            parts = [p.strip('"') for p in line.split('" "')]
            items.append({'raw': line, 'name': parts[-1].strip('"') if parts else line})
except Exception:
    pass
if not items:
    for card in pathlib.Path('/sys/class/drm').glob('card[0-9]'):
        vendor = ''
        device = ''
        try:
            vendor = (card / 'device/vendor').read_text(encoding='utf-8').strip()
            device = (card / 'device/device').read_text(encoding='utf-8').strip()
        except OSError:
            pass
        items.append({'name': card.name, 'vendor': vendor, 'device': device})
print(json.dumps(items))
PY
}

read_ac_power_json() {
    python3 - <<'PY'
import glob, json, os
items = []
for path in glob.glob('/sys/class/power_supply/*'):
    name = os.path.basename(path)
    try:
        typ = open(os.path.join(path, 'type'), encoding='utf-8').read().strip()
    except OSError:
        continue
    if typ not in ('Mains', 'USB', 'USB_CDP', 'USB_DCP', 'USB_PD'):
        continue
    online = ''
    try:
        online = open(os.path.join(path, 'online'), encoding='utf-8').read().strip()
    except OSError:
        pass
    items.append({'name': name, 'type': typ, 'online': online == '1' if online else None})
print(json.dumps(items))
PY
}

read_media_json() {
    python3 - <<'PY'
import json, pathlib, subprocess
audio = []
webcams = []
try:
    out = subprocess.run(['lspci', '-mm'], text=True, capture_output=True, timeout=8).stdout
    for line in out.splitlines():
        if 'audio device' in line.lower() or 'multimedia audio controller' in line.lower():
            audio.append(line)
except Exception:
    pass
for dev in pathlib.Path('/sys/class/video4linux').glob('video*'):
    name = ''
    try:
        name = (dev / 'name').read_text(encoding='utf-8').strip()
    except OSError:
        pass
    webcams.append({'device': '/dev/' + dev.name, 'name': name})
print(json.dumps({'audio_devices': audio, 'webcams': webcams}))
PY
}

read_battery_json() {
    python3 - <<'PY'
import glob, json, os
items = []
for path in glob.glob('/sys/class/power_supply/BAT*'):
    def read(name):
        try:
            return open(os.path.join(path, name), encoding='utf-8').read().strip()
        except OSError:
            return ''
    design = read('energy_full_design') or read('charge_full_design')
    full = read('energy_full') or read('charge_full')
    status = read('status')
    cycles = read('cycle_count')
    health = None
    wear = None
    try:
        if design and full and int(design) > 0:
            health = round(int(full) * 100 / int(design), 1)
            wear = round(100 - health, 1)
    except ValueError:
        pass
    items.append({
        'name': os.path.basename(path),
        'status': status,
        'health_percent': health,
        'wear_percent': wear,
        'cycle_count': cycles or None
    })
print(json.dumps(items))
PY
}

read_disks_json() {
    python3 - <<'PY'
import glob, json, os, subprocess
items = []
for dev in sorted(glob.glob('/sys/block/*')):
    name = os.path.basename(dev)
    if name.startswith(('loop', 'ram', 'sr')):
        continue
    def read(rel):
        try:
            return open(os.path.join(dev, rel), encoding='utf-8').read().strip()
        except OSError:
            return ''
    size = read('size')
    gb = None
    try:
        gb = round(int(size) * 512 / 1000 / 1000 / 1000, 1)
    except ValueError:
        pass
    model = read('device/model') or read('device/name')
    serial = read('device/serial')
    vendor = read('device/vendor')
    firmware = read('device/firmware_rev') or read('device/rev')
    bus = ''
    try:
        p = subprocess.run(['lsblk', '-dno', 'TRAN', f'/dev/{name}'], text=True, capture_output=True, timeout=5)
        bus = p.stdout.strip()
    except Exception:
        pass
    rotational = read('queue/rotational')
    dtype = 'HDD' if rotational == '1' else 'SSD/NVMe'
    smart = 'unknown'
    smart_detail = ''
    if os.path.exists('/usr/sbin/smartctl') or os.path.exists('/usr/bin/smartctl'):
        try:
            p = subprocess.run(['smartctl', '-H', f'/dev/{name}'], text=True, capture_output=True, timeout=10)
            out = p.stdout + p.stderr
            smart_detail = out.strip()[:1000]
            if 'PASSED' in out:
                smart = 'passed'
            elif 'FAILED' in out or 'failure' in out.lower():
                smart = 'failed'
        except Exception:
            pass
    items.append({
        'name': name,
        'path': f'/dev/{name}',
        'model': model,
        'vendor': vendor,
        'serial_number': serial,
        'firmware': firmware,
        'bus': bus,
        'type': dtype,
        'size_gb': gb,
        'smart': smart,
        'smart_detail': smart_detail,
    })
print(json.dumps(items))
PY
}

quick_cpu_test() {
    local start end
    start="$(date +%s)"
    timeout 5s sh -c 'i=0; while [ $i -lt 2 ]; do yes > /dev/null & i=$((i+1)); done; wait' >/dev/null 2>&1 || true
    pkill yes >/dev/null 2>&1 || true
    end="$(date +%s)"
    printf 'ok_%ss' "$((end - start))"
}

quick_ram_test() {
    local mb
    mb="$(read_ram_mb)"
    if [[ -n "${mb}" && "${mb}" -gt 2000 ]]; then
        timeout 6s sh -c 'dd if=/dev/zero of=/tmp/forge-ram-test.bin bs=32M count=4 conv=fsync; rm -f /tmp/forge-ram-test.bin' >/dev/null 2>&1 && echo "ok" || echo "warning"
    else
        echo "limited"
    fi
}

quick_disk_test_json() {
    python3 - <<'PY'
import glob, json, os, re, subprocess
results = []
for dev in sorted(glob.glob('/sys/block/*')):
    name = os.path.basename(dev)
    if name.startswith(('loop', 'ram', 'sr')):
        continue
    result = {'name': name, 'read_test': 'skipped', 'read_mb_s': None}
    try:
        p = subprocess.run(['dd', f'if=/dev/{name}', 'of=/dev/null', 'bs=4M', 'count=16', 'iflag=direct'], text=True, capture_output=True, timeout=8)
        text = p.stderr + p.stdout
        result['read_test'] = 'ok' if p.returncode == 0 else 'warning'
        match = re.search(r'([0-9]+(?:[,.][0-9]+)?)\s*MB/s', text)
        if match:
            result['read_mb_s'] = float(match.group(1).replace(',', '.'))
    except Exception:
        result['read_test'] = 'warning'
    results.append(result)
print(json.dumps(results))
PY
}

propose_grade() {
    local battery_wear="$1" disk_bad="$2"
    if [[ "${disk_bad}" == "yes" ]]; then
        echo "D"
    elif [[ -n "${battery_wear}" ]] && awk "BEGIN {exit !(${battery_wear} > 40)}"; then
        echo "C"
    elif [[ -n "${battery_wear}" ]] && awk "BEGIN {exit !(${battery_wear} > 25)}"; then
        echo "B"
    else
        echo "A"
    fi
}

