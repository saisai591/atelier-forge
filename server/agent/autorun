    "${startx_cmd}" /root/.xinitrc -- :1 vt1 >>/tmp/aos-startx.log 2>&1
EOF
    chmod +x /tmp/aos-startx-launch.sh

    printf '\033[2J\033[H' >"${FORGE_TEST_TTY}"
    echo "AOS Deploy - ouverture Firefox tests atelier..." >"${FORGE_TEST_TTY}"
    if command -v setsid >/dev/null 2>&1; then
        setsid /tmp/aos-startx-launch.sh >/tmp/aos-startx-launch.out 2>&1 </dev/null &
    else
        nohup /tmp/aos-startx-launch.sh >/tmp/aos-startx-launch.out 2>&1 </dev/null &
    fi
    echo $! >/tmp/aos-startx-launch.pid
    return 0
}

