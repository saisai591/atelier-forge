# =============================================================================
# Atelier Forge — Configuration du serveur (openSUSE MicroOS / Podman)
# Copiez ce fichier en "config.env" et adaptez les valeurs à votre atelier.
# =============================================================================

# --- Réseau ---------------------------------------------------------------

# Adresse IP FIXE du serveur PXE sur le réseau de l'atelier.
# (Configurez une IP statique sur cette machine au préalable.)
SERVER_IP="192.168.1.10"

# Interface réseau utilisée pour le PXE (ex: eth0, enp3s0...).
# Pour la connaître : `ip -brief address`
PXE_INTERFACE="eth0"

# Sous-réseau de l'atelier (utilisé pour le mode proxyDHCP).
SUBNET="192.168.1.0"

# --- Ports des services ---------------------------------------------------
# IMPORTANT : les ports du DÉMARRAGE PXE sont imposés par la norme et NE
# peuvent PAS être déplacés (le firmware de la carte réseau les impose) :
#   - DHCP / proxyDHCP : 67/68 + 4011 (UDP)
#   - TFTP             : 69 (UDP)
#   - Samba / SMB      : 445 (WinPE l'exige)
# Seuls les ports ci-dessous sont configurables (services que nous maîtrisons).

# Plage de ports RÉSERVÉE à partir de 1950 pour les services maîtrisés :
#   1950  HTTP  (menus iPXE, WinPE, console de test)        -> HTTP_PORT
#   1951  CUPS  (impression d'étiquettes, optionnel)        -> CUPS_PORT
#   1952  Tableau de bord d'inventaire (futur module)       -> DASHBOARD_PORT
#   1953  API interne / collecte d'audit (futur module)     -> API_PORT
#   1954-1959  réservés pour de futurs modules
HTTP_PORT="1950"
CUPS_PORT="1951"
DASHBOARD_PORT="1952"   # réservé (module inventaire à venir)
API_PORT="1953"         # réservé (module API/collecte à venir)

# --- Mode DHCP ------------------------------------------------------------

# "proxy"      = RECOMMANDÉ. Cohabite avec la box/routeur (n'attribue PAS d'IP).
#                Le mode le plus sûr : il ne casse pas le réseau existant.
# "standalone" = Le serveur fait lui-même le DHCP. UNIQUEMENT sur un réseau
#                isolé SANS autre serveur DHCP (sinon conflits d'adresses !).
DHCP_MODE="proxy"

# Paramètres utilisés UNIQUEMENT en mode "standalone" :
DHCP_RANGE_START="192.168.1.100"
DHCP_RANGE_END="192.168.1.200"
DHCP_GATEWAY="192.168.1.1"
DHCP_DNS="192.168.1.1"
DHCP_NETMASK="255.255.255.0"

# --- Chemins de données sur l'hôte (persistants, montés dans les conteneurs) -

# MicroOS : /var est inscriptible et persistant -> on y stocke les données.
DATA_ROOT="/var/lib/forge"
TFTP_ROOT="${DATA_ROOT}/tftp"      # Chargeurs iPXE (servi par dnsmasq/TFTP)
HTTP_ROOT="${DATA_ROOT}/http"      # Menus iPXE, WinPE, wimboot, outils de diag
SMB_SHARE="${DATA_ROOT}/deploy"    # Stockage reseau: ISO, images WIM/ESD, pilotes, audits
AUDIT_DIR="${DATA_ROOT}/deploy/audit"   # Rapports d'audit déposés par les machines

# --- Partage Samba --------------------------------------------------------

# Nom du partage réseau vu depuis WinPE (\\SERVER_IP\deploy).
SMB_SHARE_NAME="deploy"
# Identifiants utilisés par WinPE pour monter le partage.
SMB_USER="pxe"
SMB_PASSWORD="pxe"

# --- Impression d'étiquettes (audit) -------------------------------------

# Type d'imprimante d'étiquettes :
#   "none"    = pas d'impression automatique (génère seulement le fichier)
#   "zpl"     = imprimante Zebra réseau (langage ZPL, port brut 9100)
#   "cups"    = imprimante gérée par CUPS (Brother QL, Dymo, etc.)
LABEL_PRINTER_TYPE="none"
# Pour "zpl" : IP de l'imprimante Zebra
LABEL_ZPL_HOST="192.168.1.50"
LABEL_ZPL_PORT="9100"
# Pour "cups" : nom de la file d'impression CUPS
LABEL_CUPS_QUEUE="EtiquettesAtelier"

# --- Effacement sécurisé & certificats (type Blancco, conforme NIST 800-88) -

# Dossier où sont déposés les certificats d'effacement (sur le partage).
CERT_DIR="${DATA_ROOT}/deploy/certificates"

# Méthode d'effacement par défaut :
#   "auto"          = matériel si supporté (NVMe Sanitize / ATA Secure Erase),
#                     sinon réécriture (RECOMMANDÉ).
#   "nvme-sanitize" = force NVMe Sanitize (SSD NVMe uniquement).
#   "ata-secure"    = force ATA Secure Erase (SATA).
#   "crypto"        = Cryptographic Erase : destruction de la clé de chiffrement
#                     du disque (instantané, NVMe SES=2 / SED Opal).
#   "overwrite"     = réécriture logicielle (nwipe/shred), 1 passe de zéros.
ERASE_METHOD="auto"

# Coordonnées de VOTRE société, imprimées sur le certificat.
COMPANY_NAME="Mon Atelier Reconditionnement"
COMPANY_CONTACT="contact@exemple.fr"

# --- Signature cryptographique des certificats -----------------------------
# "yes" = chaque certificat est SIGNÉ numériquement (infalsifiable + token
#         vérifiable). La clé PRIVÉE reste sur le serveur (jamais partagée).
SIGN_CERTS="yes"
# Dossier des clés (hôte uniquement, PAS sur le partage Samba).
KEYS_DIR="${DATA_ROOT}/keys"
# Signature automatique des nouveaux certificats dès qu'ils arrivent (systemd).
AUTO_SIGN="yes"
